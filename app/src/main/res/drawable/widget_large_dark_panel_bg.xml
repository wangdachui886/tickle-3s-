<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="3dp" android:top="4dp">
        <shape>
            <solid android:color="#1E000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item android:right="3dp" android:bottom="4dp">
        <shape>
            <solid android:color="#EAFFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#EEFFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
