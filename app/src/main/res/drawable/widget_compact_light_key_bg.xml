<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:left="1dp" android:top="1dp">
                <shape>
                    <solid android:color="#10000000" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item android:right="1dp" android:bottom="1dp">
                <shape>
                    <solid android:color="#F0E9E6DF" />
                    <stroke android:width="1dp" android:color="#D2D0CAC2" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:left="1dp" android:top="2dp">
                <shape>
                    <solid android:color="#1A000000" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item android:right="1dp" android:bottom="2dp">
                <shape>
                    <solid android:color="#E8FFFFFF" />
                    <stroke android:width="1dp" android:color="#DFFFFFFF" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
