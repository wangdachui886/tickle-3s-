<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:left="1dp" android:top="1dp">
                <shape>
                    <solid android:color="#14000000" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item android:right="1dp" android:bottom="1dp">
                <shape>
                    <solid android:color="#EAF8F7F2" />
                    <stroke android:width="1dp" android:color="#EEFFFFFF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:left="1dp" android:top="2dp">
                <shape>
                    <solid android:color="#22000000" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item android:right="1dp" android:bottom="2dp">
                <shape>
                    <solid android:color="#F2F8F7F2" />
                    <stroke android:width="1dp" android:color="#F6FFFFFF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
