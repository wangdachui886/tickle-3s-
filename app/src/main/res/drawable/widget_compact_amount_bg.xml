<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:left="1dp" android:top="2dp">
                <shape>
                    <solid android:color="#22000000" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item android:right="1dp" android:bottom="2dp">
                <shape>
                    <solid android:color="#DF151716" />
                    <stroke
                        android:width="1dp"
                        android:color="#38FFFFFF" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:left="1dp" android:top="3dp">
                <shape>
                    <solid android:color="#30000000" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item android:right="1dp" android:bottom="3dp">
                <shape>
                    <solid android:color="#EA171918" />
                    <stroke
                        android:width="1dp"
                        android:color="#42FFFFFF" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
