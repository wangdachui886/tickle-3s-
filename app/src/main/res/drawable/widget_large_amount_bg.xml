<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:left="2dp" android:top="3dp">
                <shape>
                    <solid android:color="#26000000" />
                    <corners android:radius="32dp" />
                </shape>
            </item>
            <item android:right="2dp" android:bottom="3dp">
                <shape>
                    <solid android:color="#DF151716" />
                    <stroke
                        android:width="1dp"
                        android:color="#3CFFFFFF" />
                    <corners android:radius="32dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:left="2dp" android:top="4dp">
                <shape>
                    <solid android:color="#34000000" />
                    <corners android:radius="32dp" />
                </shape>
            </item>
            <item android:right="2dp" android:bottom="4dp">
                <shape>
                    <solid android:color="#EA171918" />
                    <stroke
                        android:width="1dp"
                        android:color="#46FFFFFF" />
                    <corners android:radius="32dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
