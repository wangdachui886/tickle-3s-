<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:left="1dp" android:top="1dp">
                <shape>
                    <solid android:color="#18000000" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item android:right="1dp" android:bottom="1dp">
                <shape>
                    <solid android:color="#E0141615" />
                    <stroke android:width="1dp" android:color="#46FFFFFF" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:left="1dp" android:top="2dp">
                <shape>
                    <solid android:color="#2A000000" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item android:right="1dp" android:bottom="2dp">
                <shape>
                    <solid android:color="#EC151716" />
                    <stroke android:width="1dp" android:color="#50FFFFFF" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
