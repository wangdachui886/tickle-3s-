<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:left="2dp" android:top="2dp">
                <shape>
                    <solid android:color="#18000000" />
                    <corners android:radius="22dp" />
                </shape>
            </item>
            <item android:right="2dp" android:bottom="2dp">
                <shape>
                    <solid android:color="#E0525550" />
                    <stroke android:width="1dp" android:color="#38FFFFFF" />
                    <corners android:radius="22dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:left="2dp" android:top="3dp">
                <shape>
                    <solid android:color="#26000000" />
                    <corners android:radius="22dp" />
                </shape>
            </item>
            <item android:right="2dp" android:bottom="3dp">
                <shape>
                    <solid android:color="#C9444642" />
                    <stroke android:width="1dp" android:color="#30FFFFFF" />
                    <corners android:radius="22dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
