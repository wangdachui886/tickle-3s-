<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="216dp"
        android:layout_gravity="center"
        android:background="@drawable/widget_compact_light_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="24dp"
        android:paddingTop="20dp"
        android:paddingRight="18dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:id="@+id/widget_summary_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="126"
            android:background="@drawable/widget_compact_light_panel_bg"
            android:orientation="vertical">

            <TextView android:text=""
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="36" />

            <TextView
                android:id="@+id/widget_date"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="20"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="今日支出"
                android:textColor="#777771"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView android:text=""
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="4" />

            <TextView
                android:id="@+id/widget_net_amount"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="40"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="¥117.00"
                android:textColor="#000000"
                android:textSize="26.5sp"
                android:textStyle="bold" />

            <TextView android:text=""
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/widget_flow_summary"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="22"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="5 笔"
                android:textColor="#777771"
                android:textSize="14.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_pending"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="18"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="点按切换收入"
                android:textColor="#777771"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView android:text=""
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="3" />
        </LinearLayout>

        <TextView android:text=""
            android:layout_width="27dp"
            android:layout_height="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="191"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/widget_amount_box"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="37"
                android:background="@drawable/widget_compact_amount_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingLeft="20dp"
                    android:paddingRight="18dp">

                    <TextView
                        android:id="@+id/widget_draft_meta"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="72"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="支出・餐饮"
                        android:textColor="#E9E9E4"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/widget_draft_amount"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="70"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="¥0.00"
                        android:textColor="#FFFFFF"
                        android:textSize="17.5sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <TextView android:text=""
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="5" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="24"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_plus_one"
                    style="@style/WidgetCompactLightKey"
                    android:text="+1" />

                <TextView android:text=""
                    android:layout_width="4dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/widget_plus_five"
                    style="@style/WidgetCompactLightKey"
                    android:text="+5" />

                <TextView android:text=""
                    android:layout_width="5dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/widget_plus_ten"
                    style="@style/WidgetCompactLightKey"
                    android:text="+10" />
            </LinearLayout>

            <TextView android:text=""
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="5" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="24"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_plus_fifty"
                    style="@style/WidgetCompactLightKey"
                    android:text="+50" />

                <TextView android:text=""
                    android:layout_width="4dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/widget_minus_one"
                    style="@style/WidgetCompactLightKey"
                    android:text="-1" />

                <TextView android:text=""
                    android:layout_width="5dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/widget_minus_five"
                    style="@style/WidgetCompactLightKey"
                    android:text="-5" />
            </LinearLayout>

            <TextView android:text=""
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="7" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="24"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_category_first"
                    style="@style/WidgetCompactLightKey"
                    android:background="@drawable/widget_compact_selected_bg"
                    android:text="餐饮"
                    android:textColor="#F8F7F2" />

                <TextView android:text=""
                    android:layout_width="4dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/widget_category_second"
                    style="@style/WidgetCompactLightKey"
                    android:text="交通" />

                <TextView android:text=""
                    android:layout_width="5dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/widget_category_third"
                    style="@style/WidgetCompactLightKey"
                    android:text="购物" />
            </LinearLayout>

            <TextView android:text=""
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="4" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="24"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_category_fourth"
                    style="@style/WidgetCompactLightKey"
                    android:text="娱乐" />

                <TextView android:text=""
                    android:layout_width="4dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/widget_category_other"
                    style="@style/WidgetCompactLightKey"
                    android:text="其他" />

                <TextView android:text=""
                    android:layout_width="5dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/widget_save"
                    style="@style/WidgetCompactLightKey"
                    android:background="@drawable/widget_compact_selected_bg"
                    android:text="记入"
                    android:textColor="#F8F7F2" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>

