<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="6dp"
    android:paddingTop="6dp"
    android:paddingRight="6dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_large_light_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="14dp"
        android:paddingTop="14dp"
        android:paddingRight="14dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="310"
            android:background="@drawable/widget_large_light_panel_bg"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingLeft="12dp"
            android:paddingRight="8dp"
            android:paddingBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="54"
                android:text="" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="30"
                android:ellipsize="end"
                android:gravity="left|center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="今日支出"
                android:textColor="#777771"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="72"
                android:ellipsize="end"
                android:gravity="left|center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="¥0.00"
                android:textColor="#000000"
                android:textSize="25sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="30"
                android:ellipsize="end"
                android:gravity="left|center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="0 笔"
                android:textColor="#777771"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="72"
                android:ellipsize="end"
                android:gravity="left|center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="点类型切换收入"
                android:textColor="#777771"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="10dp"
            android:layout_height="1dp"
            android:text="" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="557"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="172"
                android:background="@drawable/widget_large_amount_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="22dp"
                    android:ellipsize="end"
                    android:gravity="center|bottom"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="支出・餐饮"
                    android:textColor="#E9E9E4"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:ellipsize="end"
                    android:gravity="center|top"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="¥0.00"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="27" android:text="" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="155" android:orientation="horizontal">
                <TextView style="@style/WidgetLargeLightKey" android:text="+1" />
                <TextView android:layout_width="8dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetLargeLightKey" android:text="+5" />
                <TextView android:layout_width="8dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetLargeLightKey" android:text="+10" />
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="19" android:text="" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="155" android:orientation="horizontal">
                <TextView style="@style/WidgetLargeLightKey" android:text="+50" />
                <TextView android:layout_width="8dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetLargeLightKey" android:text="-1" />
                <TextView android:layout_width="8dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetLargeLightKey" android:text="-5" />
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="94" android:text="" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="155" android:orientation="horizontal">
                <TextView style="@style/WidgetLargeLightKey" android:background="@drawable/widget_large_selected_bg" android:text="餐饮" android:textColor="#F8F7F2" />
                <TextView android:layout_width="8dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetLargeLightKey" android:text="交通" />
                <TextView android:layout_width="8dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetLargeLightKey" android:text="购物" />
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="18" android:text="" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="155" android:orientation="horizontal">
                <TextView style="@style/WidgetLargeLightKey" android:text="娱乐" />
                <TextView android:layout_width="8dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetLargeLightKey" android:text="其他" />
                <TextView android:layout_width="8dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetLargeLightKey" android:background="@drawable/widget_large_selected_bg" android:text="记入" android:textColor="#F8F7F2" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
