<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="14dp"
    android:paddingTop="14dp"
    android:paddingRight="14dp"
    android:paddingBottom="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_compact_light_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingTop="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="126"
            android:background="@drawable/widget_compact_light_panel_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="26"
                android:gravity="center|bottom"
                android:includeFontPadding="false"
                android:text="今日支出"
                android:textColor="#777771"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="40"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="¥117.00"
                android:textColor="#000000"
                android:textSize="25sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="24"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="5 笔"
                android:textColor="#777771"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="22"
                android:ellipsize="end"
                android:gravity="center|top"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:singleLine="true"
                android:text="点按切换收入"
                android:textColor="#777771"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="22dp"
            android:layout_height="1dp"
            android:text="" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="191"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="37"
                android:background="@drawable/widget_compact_amount_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingLeft="18dp"
                    android:paddingRight="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="72"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="支出・餐饮"
                        android:textColor="#E9E9E4"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="70"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="¥0.00"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="5" android:text="" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="24" android:orientation="horizontal">
                <TextView style="@style/WidgetCompactLightKey" android:text="+1" />
                <TextView android:layout_width="4dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetCompactLightKey" android:text="+5" />
                <TextView android:layout_width="5dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetCompactLightKey" android:text="+10" />
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="5" android:text="" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="24" android:orientation="horizontal">
                <TextView style="@style/WidgetCompactLightKey" android:text="+50" />
                <TextView android:layout_width="4dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetCompactLightKey" android:text="-1" />
                <TextView android:layout_width="5dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetCompactLightKey" android:text="-5" />
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="7" android:text="" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="24" android:orientation="horizontal">
                <TextView style="@style/WidgetCompactLightKey" android:background="@drawable/widget_compact_selected_bg" android:text="餐饮" android:textColor="#F8F7F2" />
                <TextView android:layout_width="4dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetCompactLightKey" android:text="交通" />
                <TextView android:layout_width="5dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetCompactLightKey" android:text="购物" />
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="4" android:text="" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="24" android:orientation="horizontal">
                <TextView style="@style/WidgetCompactLightKey" android:text="娱乐" />
                <TextView android:layout_width="4dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetCompactLightKey" android:text="其他" />
                <TextView android:layout_width="5dp" android:layout_height="1dp" android:text="" />
                <TextView style="@style/WidgetCompactLightKey" android:background="@drawable/widget_compact_selected_bg" android:text="记入" android:textColor="#F8F7F2" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
